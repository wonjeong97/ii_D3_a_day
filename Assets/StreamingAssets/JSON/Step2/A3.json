          "fontSize": 28,
          "fontColor": {"r": 0.1960784, "g": 0.1960784, "b": 0.1960784, "a": 1},
          "alignment": 0
        },
        "textAnswer3": {
          "name": "Text_A3",
          "position": {"x": -125, "y": 176},
          "scale": {"x": 1, "y": 1, "z": 1},
          "text": "ㄷ. 가끔\n조절이 필요해",
          "fontName": "font8",
          "fontSize": 28,
          "fontColor": {"r": 0.1960784, "g": 0.1960784, "b": 0.1960784, "a": 1},
          "alignment": 0
        },
        "textAnswer4": {
          "name": "Text_A4",
          "position": {"x": -125, "y": 176},
          "scale": {"x": 1, "y": 1, "z": 1},
          "text": "ㄹ. 조금\n멀게 느껴져",
