          "fontColor": {"r": 0.1960784, "g": 0.1960784, "b": 0.1960784, "a": 1},
          "alignment": 0
        },
        "textAnswer2": {
          "name": "Text_A2",
          "position": {"x": -125, "y": 176},
          "scale": {"x": 1, "y": 1, "z": 1},
          "text": "ㄴ. 도와주며\n부담을 나눠줘",
