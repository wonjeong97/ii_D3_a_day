          "fontSize": 28,
          "fontColor": {"r": 0.1960784, "g": 0.1960784, "b": 0.1960784, "a": 1},
          "alignment": 0
        },
        "textAnswer2": {
          "name": "Text_A2",
          "position": {"x": -125, "y": 176},
          "scale": {"x": 1, "y": 1, "z": 1},
          "text": "ㄴ. 서로의\n의견을 존중해",
          "fontName": "font8",
          "fontSize": 28,
          "fontColor": {"r": 0.1960784, "g": 0.1960784, "b": 0.1960784, "a": 1},
          "alignment": 0
        },
        "textAnswer3": {
          "name": "Text_A3",
          "position": {"x": -125, "y": 176},
          "scale": {"x": 1, "y": 1, "z": 1},
          "text": "ㄷ. 신중하게\n선을 지켜",
